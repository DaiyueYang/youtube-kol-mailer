# ========================================
# YouTube KOL Mailer 环境配置
# ========================================
#
# 使用方式：
#   1. cp .env.example .env
#   2. 填入真实值
#   3. 不要将 .env 提交到版本控制
#
# 标注说明：
#   [必填] 系统启动/登录必须填写
#   [可选] 有默认值，可不配置
#   [非主路径] 代码仍读取但不是当前主流程所必需

# ── 应用基础 [可选] ──
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# ── 数据库 [可选] ──
DB_PATH=./data/app.db

# ══════════════════════════════════════
# OAuth / 飞书应用（登录必需）
# ══════════════════════════════════════

# [必填] 飞书/Lark 应用凭证
# 在飞书开放平台（open.feishu.cn/app）或 Lark（open.larksuite.com/app）创建企业自建应用后获取
# 用于 OAuth 登录、获取 tenant_access_token、Bot 消息发送
LARK_APP_ID=cli_your_app_id
LARK_APP_SECRET=your_app_secret

# [必填] 飞书 API 基础地址 — 必须与你创建应用的平台一致
# 飞书国内版: https://open.feishu.cn/open-apis
# Lark 国际版: https://open.larksuite.com/open-apis
# ⚠️ 填错会导致 tenant_token 返回 invalid param
LARK_API_BASE=https://open.larksuite.com/open-apis

# [必填] OAuth 回调地址 — 必须与飞书开放平台后台「安全设置 > 重定向 URL」一致
OAUTH_REDIRECT_URI=https://api.youtube-kol.com/api/auth/callback

# ══════════════════════════════════════
# Bitable 多维表格
# ══════════════════════════════════════

# [非主路径] 全局 Bitable 配置
# 当前系统中，每个用户在 Dashboard 登录后自行创建/选择表格，
# 配置保存在用户数据库记录中，不依赖此处的全局值。
# 以下变量仅作为未登录时的全局 fallback，正常使用可留空。
LARK_BITABLE_APP_TOKEN=
LARK_BITABLE_TABLE_ID=

# ══════════════════════════════════════
# SMTP 邮件发送
# ══════════════════════════════════════

# [非主路径] 全局 SMTP 配置
# 当前系统中，邮件发送 100% 使用用户级 SMTP：每个用户在 Dashboard 配置自己的邮箱和密码。
# 以下全局 SMTP 变量不再是发送主链路所必需。
# SmtpService 默认实例会读取这些值，但所有发送 API 已切换到用户级配置。
# 如果你没有多用户需求、只有单人使用，也可以填写此处并在 Dashboard 中使用相同邮箱。
LARK_SMTP_HOST=smtp.larksuite.com
LARK_SMTP_PORT=465
LARK_SMTP_USER=
LARK_SMTP_PASSWORD=
LARK_SMTP_FROM_NAME=

# ══════════════════════════════════════
# 发送参数
# ══════════════════════════════════════

# [非主路径] 全局预览邮箱 — 用户未登录时的 fallback
# 登录用户的预览邮箱从 Dashboard「SMTP 配置」中读取，不依赖此变量。
PREVIEW_RECEIVER_EMAIL=

# [可选] 批量发送时每封邮件之间的随机延迟（秒）
SEND_DELAY_MIN=5
SEND_DELAY_MAX=15

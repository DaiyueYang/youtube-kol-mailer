# ========================================
# YouTube KOL Mailer 环境配置
# ========================================
#
# 使用方式：
#   1. 复制此文件为 .env：  cp .env.example .env
#   2. 填入你的真实值（所有标注 [必填] 的项目）
#   3. 不要将 .env 提交到版本控制
#
# 标注说明：
#   [必填]  - 系统运行必须填写，否则对应功能不可用
#   [可选]  - 有默认值，可不修改
#   [示例值] - 当前值仅为占位示例，不是真实配置
#

# ── 应用基础 [可选] ──
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

# ── 数据库 [可选] ──
DB_PATH=./data/app.db

# ── 飞书 API 基础地址 [重要] ──
# 飞书国内版: https://open.feishu.cn/open-apis
# Lark 国际版: https://open.larksuite.com/open-apis
# ⚠️ 必须与你创建应用的平台一致，否则 tenant_token 会返回 invalid param
LARK_API_BASE=            # [必填] 见上方说明

# ── 飞书应用凭证 [必填] ──
# 在飞书开放平台创建应用后获取
# https://open.feishu.cn/app 或 https://open.larksuite.com/app
LARK_APP_ID=              # [示例值] cli_a1b2c3d4e5f6
LARK_APP_SECRET=          # [示例值] xxxxxxxxxxxxxxxxxxxx

# ── 飞书 Bitable [必填] ──
# 打开你的多维表格，从 URL 中获取 app_token 和 table_id
# URL 格式: https://xxx.feishu.cn/base/{app_token}?table={table_id}
LARK_BITABLE_APP_TOKEN=   # [示例值] bascnXXXXXXXXXXXXX
LARK_BITABLE_TABLE_ID=    # [示例值] tblXXXXXXXXXXXXXXX

# ── 飞书 SMTP [必填] ──
# 飞书企业邮箱 SMTP 配置，SSL 465
# 在飞书管理后台 > 邮箱 > 客户端密码 中获取
LARK_SMTP_HOST=smtp.larksuite.com
LARK_SMTP_PORT=465
LARK_SMTP_USER=           # [示例值] your_name@yourcompany.com
LARK_SMTP_PASSWORD=       # [示例值] 飞书邮箱客户端专用密码
LARK_SMTP_FROM_NAME=      # [可选] 发件人显示名，如 "Brian from TeamXYZ"

# ── 飞书 Bot [必填] ──
# 在飞书群设置中添加自定义机器人后获取 Webhook URL
LARK_BOT_WEBHOOK=         # [示例值] https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# ── 发送配置 ──
PREVIEW_RECEIVER_EMAIL=   # [必填] 预览邮件接收地址（你自己的邮箱）
SEND_DELAY_MIN=5          # [可选] 每封邮件之间最小延迟（秒）
SEND_DELAY_MAX=15         # [可选] 每封邮件之间最大延迟（秒）
DAILY_LIMIT=20            # [可选] 每日发送上限

# ── Admin 页面 [可选] ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me  # 生产环境请修改
